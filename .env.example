# ================================================
# CONFIGURACIÓN DE TROPICOLORS
# ================================================
# Copia este archivo a .env y completa los valores

# ================================================
# STRIPE (Requerido para pagos)
# ================================================
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================================================
# EMAIL (SMTP) - Opcional para correos
# ================================================
# Configuración SMTP para enviar correos
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=tu-email@gmail.com
EMAIL_SMTP_PASS=tu-app-password
EMAIL_FROM=noreply@tropicolors.mx
EMAIL_TO=tropicolors@hotmail.com

# ================================================
# TWILIO (WhatsApp) - Opcional
# ================================================
#TWILIO_ACCOUNT_SID=your_twilio_sid
#TWILIO_AUTH_TOKEN=your_twilio_token
#TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#WHATSAPP_ADMIN_NUMBER=whatsapp:+525551146856

# ================================================
# APP CONFIG
# ================================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:5173

# URL de tu base de datos (si usas una)
# DATABASE_URL=postgresql://...

# Seguridad
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# SESSION_SECRET=your-random-secret-key
